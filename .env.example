# ZapLead Website Environment Variables
# Copy this file to .env.local and fill in your values

# Site URL (for absolute URLs in metadata)
NEXT_PUBLIC_SITE_URL=https://zaplead.in

# WhatsApp funnel / QR redirect
# Use the permanent Render backend domain here, not ngrok.
# Website WhatsApp buttons resolve to `${WHATSAPP_WEBHOOK_BASE_URL}/qr/main`.
WHATSAPP_WEBHOOK_BASE_URL=https://your-render-backend.onrender.com
# Optional full-URL override:
# NEXT_PUBLIC_WHATSAPP_FUNNEL_URL=https://your-render-backend.onrender.com/qr/main

# Chatbot (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-5.4

# Contact Form Integration (optional)
# Uncomment and fill in when you're ready to connect your CRM

# Example: HubSpot
# HUBSPOT_API_KEY=your_api_key_here
# HUBSPOT_PORTAL_ID=your_portal_id_here

# Example: SendGrid for email notifications
# SENDGRID_API_KEY=your_api_key_here
# NOTIFICATION_EMAIL=aizaplead@gmail.com

# Example: generic webhook for contact submissions
# CONTACT_WEBHOOK_URL=https://your-automation-or-crm.example.com/hooks/contact

# Example: Google Sheets
# GOOGLE_SHEETS_CLIENT_EMAIL=your_service_account_email
# GOOGLE_SHEETS_PRIVATE_KEY=your_private_key
# GOOGLE_SHEETS_SHEET_ID=your_sheet_id

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=zaplead.in
